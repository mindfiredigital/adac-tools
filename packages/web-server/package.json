{
  "name": "@mindfiredigital/adac-web-server",
  "version": "0.0.1",
  "description": "Express API server for ADAC diagram generation and compliance services",
  "author": "Mindfire Digital",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "keywords": [
    "adac",
    "api",
    "web-server",
    "express",
    "diagram"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@mindfiredigital/adac-compliance": "workspace:*",
    "@mindfiredigital/adac-cost": "workspace:*",
    "@mindfiredigital/adac-diagram": "workspace:*",
    "@mindfiredigital/adac-optimizer": "workspace:*",
    "@mindfiredigital/adac-schema": "workspace:*",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^2.0.12",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mindfiredigital/adac-tools.git",
    "directory": "packages/web-server"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ]
}
