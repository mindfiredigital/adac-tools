{
  "name": "@mindfiredigital/adac-diagram",
  "version": "0.1.0",
  "description": "Core engine and CLI for ADAC (AWS Diagram As Code) generator",
  "author": "Mindfire Digital",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "adac": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mindfiredigital/adac-tools.git",
    "directory": "packages/diagram"
  },
  "keywords": [
    "adac",
    "aws",
    "diagram",
    "elkjs",
    "architecture",
    "cloud"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@mindfiredigital/adac-compliance": "workspace:*",
    "@mindfiredigital/adac-cost": "workspace:*",
    "@mindfiredigital/adac-export-terraform": "workspace:*",
    "elkjs": "^0.11.0",
    "fs-extra": "^11.3.3"
  },
  "devDependencies": {
    "@mindfiredigital/adac-cli": "workspace:*",
    "@mindfiredigital/adac-core": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "tsup": "^8.3.5",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  }
}
